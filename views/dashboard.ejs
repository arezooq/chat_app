<%- include('layouts/header.ejs') %>

<div class="container">
    <div class="row clearfix">
        <div class="col-lg-12">
            <div class="card chat-app">
  
                <div id="plist" class="people-list">
                  <ul class="menu">
                    <li>   
                      <div class="input-group" style="border-bottom: 2px solid #f0f7f5">
                      <img src="<%= user.image %>" style="width: 50px;height: 50px;border-radius: 50%;margin-bottom: 2px;" data-id="<%= user.image %>" alt="avatar" class="img-user">
                      <div class="about" style="margin-bottom: 2px;">
                          <div class="nameUser" data-id="<%= user.name %>"><%= user.name %></div>
                          <%
                          if( user.is_online !== 0 ){ %>
                          <div class="status" id="<%= user.phone %>-status" data-id="<%= user.is_online %>"> <i class="fa fa-circle online"></i> online </div>
                          <% } else { %>
                          <div class="status" id="<%= user.phone%>-status"  data-id="<%= user.is_online %>"> <i class="fa fa-circle offline"></i> offline </div>  
                          <% } %>
                      </div>
                    </div>
                    </li>
                    <div class="header">
      
      <div class="dropdown hidden-sm text-right">
          <ul class="dropbtn icons btn-right showLeft" onclick="showDropdown()">
              <li></li>
              <li></li>
              <li></li>
              <div id="myDropdown" class="dropdown-content">
                  <a href="" id="editUser" class="btn btn-outline-secondary" data-id="<%= user.phone %>" data-name="<%= user.name %>" data-toggle="modal" data-target="#editUserModal">Edit Name</a>                      
                  <a href="/logout" class="btn btn-outline-secondary">Log Out</a>
              </div>
          </ul>
      
      </div>
      
      </div>
     </ul>
         <button class="hamburger">
            <i class="menuIcon material-icons">menu</i>
            <i class="closeIcon material-icons">close</i>
         </button>
                    <ul class="list-unstyled contact-list mt-2 mb-0">
                      <% if ( users !== '' && contacts !== ''){
                        for(let x=0; x < users.length; x++){
                      %>
                      <li class="clearfix user-list" data-name="<%= contacts[x].name %>" data-phone="<%= users[x].phone %>" data-is_online="<%= users[x].is_online %>" data-img="<%= users[x].image %>" id="userList">
                        <img src="<%= users[x].image %>" alt="avatar">
                        <div class="about">
                            <div class="nameContact" data-id="<%= contacts[x].name %>"><%= contacts[x].name %></div>
                            <%
                          if( users[x].is_online == 1 ){ %>
                          <div class="status" id="<%= users[x].phone %>-status" data-id="<%= users[x].is_online %>"> <i class="fa fa-circle online"></i> online </div>
                          <% } else { %>
                          <div class="status" id="<%= users[x].phone%>-status"  data-id="<%= users[x].is_online %>"> <i class="fa fa-circle offline"></i> offline </div>  
                          <% } %>
                        </div>
                        <div class="message lastChat">
                          <%= lastChat %>
                        </div>
                       
                    </li>
                    <%
                    }
                  }
                    if(users == ''){
                      %>
                    <h5 class="noMessage">You Have No Contacts yet...!</h5>
                      <% } %>

                  </ul>
                  
                  <div><i class="fa fa-user-plus" id="createContact" style="font-size: 48px;" data-id="<%= user.phone %>" data-toggle="modal" data-target="#createContactModal"></i></div>

                </div>
                <div class="chat">
                    <div class="chat-header clearfix">
                        <div class="row">
                            <div class="contact-about col-lg-6">

                            </div>
                        </div>
                    </div>
                    <div class="chat-history">
                        <ul class="m-b-0">
                  
                          

                        </ul>
                    </div>
                    <div class="chat-message clearfix">
                      <form action="" id="chat-form">
                        <div class="input-group mb-0">
                          <input type="text" name="message" id="message" class="form-control" placeholder="Enter text here...">                                    
                            <div class="input-group-prepend">
                              <button type="submit" class="input-group-text">
                               <i class="fa fa-send"></i>
                              </button>
                            </div>
                        </div>
                      </form>
                    </div>
                </div>
            </div>
        </div>

 <!-- Delete Chat -->
    


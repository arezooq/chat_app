<script>

  var sender_id = '<%= user.phone %>'
var receiver_id;
var socket = io('/user-namespace', {
  auth: {
    token: '<%= user.phone %>'
  }
})

$(document).ready(function() {

  $('.user-list').click(function(){

    var userId = $(this).attr('data-phone')
    receiver_id = userId
    var nameContact = $(this).attr('data-name')
    var imgContact = $(this).attr('data-img')
    var isOnlineContact = $(this).attr('data-is_online')

let html =  `
<a href="javascript:void(0);" data-toggle="modal" data-target="#view_info">
 <img src="${imgContact}" alt="avatar">
</a>
<div class="chat-about">
  <h6 class="m-b-0">${nameContact}</h6>
  `
  if(isOnlineContact == 1){
 html+= `<small><div class="status" id="${receiver_id}-status" data-id="${isOnlineContact}"> <i class="fa fa-circle online"></i> online </div></small>`
  } else {
    html+= `<small><div class="status" id="${receiver_id}-status"  data-id="${isOnlineContact}"> <i class="fa fa-circle offline"></i> offline </div></small>`
  }
  html+= `
  <div class="dropdown hidden-sm text-right">
<ul class="dropbtn icons btn-left" onclick="showRightMenu()">
<li></li>
<li></li>
<li></li>
    <div id="myRightMenu" class="dropdown-content">
      <a href="" id="editContact" class="btn btn-outline-secondary" data-id="${receiver_id}" data-name="${nameContact}" data-toggle="modal" data-target="#editContactModal">Edit Contact</a>                      
      <a href="" id="deleteContact" class="btn btn-outline-secondary" data-id="${receiver_id}" data-name="${nameContact}" data-toggle="modal" data-target="#deleteContactModal">Delete Contact</a>                      
    </div>
  </ul>
 </div>
 </div>
  `

$('.contact-about').append(html)

    socket.emit('existsChat', { sender_id: sender_id, receiver_id: receiver_id })
  })
  
  
});


// chat save of user

$('.chat-message').submit(function(event){
  event.preventDefault()

  var message = $('#message').val()

  $.ajax({
    url:'/save-chat',
    type: 'POST',
    data: { sender_id: sender_id, receiver_id: receiver_id, message: message },
    success: function(response){
      if(response.success){
        $('#message').val('')
        let chat = response.data.message
        let html = `
        <li class="clearfix" id="${response.data.phone}">
         <div class="message-data">
          <span class="message-data-time">${response.data.createdAt}</span>
         </div>
         <div class="message my-message">${chat}
          <i class="fa fa-trash" aria-hidden="true" data-id="${response.data.id}" data-toggle="modal" data-target="#deleteChatModal"></i>
          <i class="fa fa-edit" aria-hidden="true" data-id="${response.data.id}" data-msg="${chat}" data-toggle="modal" data-target="#editChatModal"></i>
          </div>                                    
        </li> 
        `;
        $('.chat-history').append(html)
        socket.emit('newChat', response.data)

        scrollChat()
      }
      else{
        alert(data.msg)
      }
    }
  })
})

socket.on('loadNewChat', function(data) {
  
  if(sender_id === data.sender_id && receiver_id === data.receiver_id){

    let html = `
    <li class="clearfix" id="${data.phone}">
    <div class="message-data text-right">
        <span class="message-data-time">${data.createdAt}</span>
    </div>
     <div class="message other-message float-right"> ${data.message} </div>
    </li>  
    `;
    $('.chat-history').append(html)
  }
  scrollChat()

})

// load old chat

socket.on('loadChats', function(data) {
  $('.chat-history').html('')
  var chats = data.chats
  
  let html = ''
  
  for(let x=0; x < chats.length; x++){
    let addClass = ''
    let date = ''
    if(chats[x].sender_id === sender_id){
      addClass = "my-message"
      date = "message-data"
    }
    else{
      addClass = "other-message float-right"
      date = "message-data text-right"
    }

    html+= `
    <li class="clearfix" id="${chats[x].phone}">
    <div class="${date}">
        <span class="message-data-time">${chats[x].createdAt}</span>
    </div>
     <div class="message ${addClass}"> ${chats[x].message}`;
    
    if(chats[x].sender_id == sender_id){
    html+= `  <i class="fa fa-trash" aria-hidden="true" data-id="${chats[x].id}" data-toggle="modal" data-target="#deleteChatModal"></i>
    <i class="fa fa-edit" aria-hidden="true" data-id="${chats[x].id}" data-msg="${chats[x].message}" data-toggle="modal" data-target="#editChatModal"></i>
    `;
    }

    html+= ` </div>
    </li> 
    `
  }

  if(chats == ''){
    html+= `
    <h5 class="noMessage">No Messages Here yet...!</h5>`
  }
  

  $('.chat-history').append(html)

  scrollChat()
})

// update user online status

socket.on('getOnlineUser', (data) => {
  $('#'+data.user_id+'-status').text('Online')
  $('#'+data.user_id+'-status').removeClass('offline-status')
  $('#'+data.user_id+'-status').addClass('online-status')

})

// update user offline status

socket.on('getOfflineUser', (data) => {
  $('#'+data.user_id+'-status').text('Offline')
  $('#'+data.user_id+'-status').removeClass('online-status')
  $('#'+data.user_id+'-status').addClass('offline-status')

})

function scrollChat(){
  $('.chat-history').animate({
    scrollTop:$('.chat-history').offset().top + $('.chat-history')[0].scrollHeight
  }, 0)
}

// delete chat

$(document).on('click', '.fa-trash', function() {
  let msg = $(this).parent().text()
  $('#delete-message').text(msg)

  $('#delete-message-id').val($(this).attr('data-id'))
})

$('#delete-chat-form').submit(function(event) {
  event.preventDefault()

  var id = $('#delete-message-id').val()

  $.ajax({
    url: '/delete-chat',
    type: 'POST',
    data: { id: id },
    success: function(res){
      if(res.success == true){
        $('#'+id).remove()
        $('#deleteChatModal').modal('hide')
        $('#deleteChatModal').hide()

        socket.emit('chatDeleted', id)
      }
      else{
        alert(res.msg)
      }
    }
  })
})

socket.on('chatMessageDeleted', function(id) {
  $('#'+id).remove()
})

// update user chat

$(document).on('click', '.fa-edit', function() {
$('#edit-message-id').val( $(this).attr('data-id') )
$('#update-message').val( $(this).attr('data-msg') )

})

$('#update-chat-form').submit(function(event) {
  event.preventDefault()

  var id = $('#edit-message-id').val()
  var msg = $('#update-message').val()

  $.ajax({
    url: '/update-chat',
    type: 'POST',
    data: { id: id, message: msg },
    success: function(res){
      if(res.success == true){
        $('#editChatModal').hide()
        location.reload();
        $('#'.id).find('.my-message').text(msg)
        $('#'.id).find('.fa-edit').attr('data-msg', msg)
        socket.emit('chatUpdated', { id: id, message: msg })
      }
      else{
        alert(res.msg)
      }
    }
  })
})

socket.on('chatMessageUpdated', function(data) {
  $('#'+data.id).find('.my-message').text(data.message)
})


// contact save of user


$(document).on('click', '.fa-user-plus', function() {
$('#createContact').val( $(this).attr('data-id') )

})

$('#create-contact-form').submit(function(event) {
  event.preventDefault()

  var name = $('#nameContact').val()
  var phone = $('#phoneContact').val()


  $.ajax({
    url: '/save-contact',
    type: 'POST',
    data: { name: name, phone: phone, user_id: sender_id },
    success: function(res){
      if(res.success == true){
        $("#createContactModal").hide(); 
        alert(res.msg)

        location.reload();
      }
      else{
        alert(res.msg)
      }
    }
  })
})


// update contact

$(document).on('click', '#editContact', function() {
$('#edit-contact-id').val( $(this).attr('data-id') )
$('#nameCont').val( $(this).attr('data-name') )

})

$('#update-contact-form').submit(function(event) {
event.preventDefault()

var id = $('#edit-contact-id').val()
var name = $('#nameCont').val()


$.ajax({
  url: '/update-contact',
  type: 'POST',
  data: { id: id, name: name, user_id: sender_id },
  success: function(res){
    if(res.success === true){
      console.log($('#'.id).find('.nameContact').text(name))
      $('#editContactModal').hide()
      $('#'.id).find('.nameContact').text(name)
      $('#'.id).find('#editContact').attr('data-name', name)
      socket.emit('contactUpdated', { id: id, name: name })
      location.reload();

    }
    else{
      alert(res.msg)
    }
  }
})
})

socket.on('contactInfoUpdated', function(data) {
$('#'+data.id).find('.nameContact').text(data.name)
})



// delete contact

$(document).on('click', '#deleteContact', function() {
  let msg = $(this).attr('data-name')
  $('#delete-contact').text(msg)

  $('#delete-contact-id').val($(this).attr('data-id'))

})

$('#delete-contact-form').submit(function(event) {
event.preventDefault()

var id = $('#delete-contact-id').val()
console.log(id)


$.ajax({
  url: '/delete-contact',
  type: 'POST',
  data: { id: id, user_id: sender_id },
  success: function(res){
    if(res.success === true){
      $('#'+id).remove()
        $("#deleteContactModal").hide();
        socket.emit('contactDeleted', id)
        location.reload();

    }
    else{
      alert(res.msg)
    }
  }
})
})

socket.on('contactInfoDeleted', function(id) {
  $('#'+id).remove()
})


  // update information user

$(document).on('click', '#editUser', function() {
$('#edit-user-id').val( $(this).attr('data-id') )
$('#nameUser').val( $(this).attr('data-name') )

})

$('#update-user-form').submit(function(event) {
event.preventDefault()

var id = $('#edit-user-id').val()
var name = $('#nameUser').val()


$.ajax({
  url: '/update-user',
  type: 'POST',
  data: { id: id, name: name },
  success: function(res){
    if(res.success === true){
      $('#editUserModal').modal('hide')
      $('#'.id).find('.userName').text(name)
      $('#'.id).find('#editUser').attr('data-name', name)
      socket.emit('userUpdated', { id: id, name: name })
      location.reload();

    }
    else{
      alert(res.msg)
    }
  }
})
})

socket.on('userInfoUpdated', function(data) {
$('#'+data.id).find('.userName').text(data.name)
})




// menu hamburger

const menuIcon = document.querySelector(".menuIcon");
const hamburger = document.querySelector(".hamburger")
const menu = document.querySelector(".menu")
const closeIcon = document.querySelector(".closeIcon");
const menuItems = document.querySelectorAll(".menuItem");

closeIcon.style.display = "none";


function toggleMenu() {
if (menu.classList.contains("showMenu")) {
  menu.classList.remove("showMenu");
  closeIcon.style.display = "none";
  menuIcon.style.display = "block";
} else {
  menu.classList.add("showMenu");
  closeIcon.style.display = "block";
  menuIcon.style.display = "none";
}
}

menuItems.forEach( 
function(menuItem) { 
  menuItem.addEventListener("click", toggleMenu);
}
)

hamburger.addEventListener("click", toggleMenu);



function changeLanguage(language) {
                  var element = document.getElementById("url");
                  element.value = language;
                  element.innerHTML = language;
              }

function showDropdown() {
document.getElementById("myDropdown").classList.toggle("show");
}

// Close the dropdown if the user clicks outside of it
window.onclick = function(event) {
if (!event.target.matches('.dropbtn')) {
  var dropdowns = document.getElementsByClassName("dropdown-content");
  var i;
  for (i = 0; i < dropdowns.length; i++) {
    var openDropdown = dropdowns[i];
    if (openDropdown.classList.contains('show')) {
      openDropdown.classList.remove('show');
    }
  }
}
}


function showRightMenu() {
document.getElementById("myRightMenu").classList.toggle("show");
}


</script>



